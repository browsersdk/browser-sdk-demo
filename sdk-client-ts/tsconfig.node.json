{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/types/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": [
      "electron-vite/node"
    ],
    "baseUrl": ".",
    "paths": {
      "@src2/*": [
        "src/*"
      ],
      "@main/*": [
        "src/main/*"
      ],
      "@type/*": [
        "src/types/*"
      ],
    }
  }
}